<?xml version='1.0' encoding='utf-8'?>
<widget id="com.xolboy.flippbird" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Flipp Bird</name>
    <description>Simple Bird Game</description>
    <author email="dev@xolboy.com" href="http://cordova.io">Xolboy Team</author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <platform name="android">
        <icon src="res/icon/icon.png" />
        <preference name="AndroidXEnabled" value="true" />
    </platform>

    <preference name="ScrollEnabled" value="false" />
</widget>
